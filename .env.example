# ─── Database ──────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/boardflow

# ─── Server ────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# ─── Auth ──────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-random-string
SESSION_MAX_AGE=604800000

# ─── CORS (comma-separated for multiple origins) ───────────────────
CORS_ORIGIN=http://localhost:3000

# ─── File Upload ───────────────────────────────────────────────────
MAX_FILE_SIZE=10485760

# ─── File Storage (local or s3) ────────────────────────────────────
STORAGE_TYPE=local
UPLOAD_DIR=./uploads
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET=boardflow-uploads
# S3_PUBLIC_URL=https://uploads.example.com

# ─── Client (Next.js) ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
# Server-only target used by Next.js to proxy browser /api requests. Set this
# to the public API URL in Vercel so session cookies remain first-party.
API_PROXY_TARGET=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════════
# DEPLOYMENT NOTES
# ═══════════════════════════════════════════════════════════════════
#
# ── Vercel (Frontend) ──
#   Set root directory to: apps/web
#   No special build settings needed — vercel.json already configured.
#
# ── Render (Backend) ──
#   Use existing render.yaml or create a Web Service pointing to this repo.
#   Set build command in Render dashboard:
#     corepack enable && corepack prepare pnpm@9.15.0 --activate && pnpm install --frozen-lockfile && pnpm --filter @boardflow/shared build && pnpm --filter @boardflow/api build
#   Set start command:
#     node apps/api/dist/index.js
#   Set health check path: /api/health
#
# ── Required Environment Variables (set in Render dashboard) ──
#   MONGODB_URI      - Your production MongoDB connection string
#   SESSION_SECRET   - Random 64-char hex string (node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
#   CORS_ORIGIN      - Your Vercel frontend URL (e.g. https://boardflow.vercel.app)
#   NODE_ENV         - production
