{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"],
      "env": [
        "MONGODB_URI", "API_PORT", "API_HOST", "NODE_ENV",
        "SESSION_SECRET", "SESSION_MAX_AGE", "CORS_ORIGIN",
        "MAX_FILE_SIZE", "STORAGE_TYPE", "UPLOAD_DIR",
        "S3_ENDPOINT", "S3_REGION", "S3_ACCESS_KEY_ID",
        "S3_SECRET_ACCESS_KEY", "S3_BUCKET", "S3_PUBLIC_URL",
        "NEXT_PUBLIC_API_URL", "NEXT_PUBLIC_APP_URL"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
